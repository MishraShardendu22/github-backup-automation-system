{
  "info": {
    "name": "GitHub Backup API",
    "description": "API collection for GitHub Backup Automation System - A Go-based system that clones, archives, and stores GitHub repositories with a Postgres-backed dashboard for visibility.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Backups",
      "description": "Backup run management endpoints",
      "item": [
        {
          "name": "List Backup Runs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has pagination', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('pagination');",
                  "});",
                  "",
                  "pm.test('Response has data array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/backups?page=1&limit=50",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "backups"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (1-indexed)"
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Results per page (1-500)"
                }
              ]
            },
            "description": "Retrieve a paginated list of backup runs in reverse chronological order"
          }
        },
        {
          "name": "Get Latest Backup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has backup run structure', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData).to.have.property('started_at');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/backups/latest",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "backups",
                "latest"
              ]
            },
            "description": "Retrieve the most recent backup run"
          }
        },
        {
          "name": "Get Backup Run Details",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has run and backup_results', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('run');",
                  "    pm.expect(jsonData).to.have.property('backup_results');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/backups/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "backups",
                "1"
              ]
            },
            "description": "Retrieve detailed information for a specific backup run including all repository results"
          }
        }
      ]
    },
